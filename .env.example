DERA_ENV=dev
DERA_DATABASE_PATH=./var/dera.sqlite3
DERA_STORAGE_ROOT=./workspace-storage
DERA_HERMES_BASE_URL=http://127.0.0.1:8000
DERA_HERMES_API_KEY=dev-local-only-replace-before-enabling-hermes
DERA_HERMES_MODEL=digital-recovery-agent
DERA_HERMES_ENABLED=false
DERA_CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DERA_API_AUTH_ENABLED=false
DERA_API_KEY=dev-local-only-replace-before-remote-use
DERA_RETENTION_DAYS=7
DERA_MAX_UPLOAD_BYTES=1000000
DERA_ALLOW_SENSITIVE_PAYLOADS=false
DERA_TTS_PROVIDER=kokoro
DERA_TTS_KOKORO_VOICE=af_heart
DERA_TTS_KOKORO_LANG_CODE=a
DERA_TTS_KOKORO_SPEED=1.0
DERA_TTS_SAMPLE_RATE=24000
DERA_TTS_MAX_CHARS=420
